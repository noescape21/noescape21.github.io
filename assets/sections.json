---
layout: null
---
{
  "sections": [
    {% assign sorted_sections = site.data.sections | sort: "order" %}
    {% for section in sorted_sections %}
    {
      "id": {{ section.id | jsonify }},
      "label": {{ section.label | jsonify }},
      "title": {{ section.title | jsonify }},
      "sub": {{ section.sub | jsonify }},
      "desc": {{ section.desc | jsonify }},
      "color": {{ section.color | jsonify }},
      "letter": {{ section.letter | jsonify }},
      "glyph": {{ section.glyph | jsonify }},
      "pixel_art": {{ section.pixel_art | jsonify }},
      "route": {{ section.route | jsonify }},
      "external": {{ section.external }},
      "meta": {{ section.meta | jsonify }},
      {% if section.id == "blog" %}
      "posts": [
        {% for post in site.posts limit:10 %}
        {
          "title": {{ post.title | jsonify }},
          "date": {{ post.date | date: "%Y.%m.%d" | jsonify }},
          "url": {{ post.url | jsonify }}
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
      {% else %}
      "posts": []
      {% endif %}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
